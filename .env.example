# API host port exposed by Docker Compose.
API_PORT=8000

# Comma-separated browser or upper-computer origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Runtime logging.
LOG_LEVEL=INFO

# Persistent runtime data paths inside the container.
ONLINE_HISTORY_DIR=/app/data/online
TABPFN_MODEL_CACHE_DIR=/app/models/tabpfn_cache

# CPU-only deployment defaults. USE_BACKUP=true skips TabPFN fit at startup
# and uses the XGBoost backup path for fast real-time inference.
MODEL_DEVICE=cpu
USE_BACKUP=true
CPU_THREADS=4
