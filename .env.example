# API host port exposed by Docker Compose.
API_PORT=8000

# Comma-separated browser or upper-computer origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Runtime logging.
LOG_LEVEL=INFO

# Persistent runtime data paths inside the container.
ONLINE_HISTORY_DIR=/app/data/online
TABPFN_MODEL_CACHE_DIR=/app/models/tabpfn_cache

# CPU 部署：TabPFN 单次推理 ~43s，用于校验 XGBoost 粗筛结果。
# 有 GPU 时设 MODEL_DEVICE=cuda 可大幅加速。
MODEL_DEVICE=cpu
USE_BACKUP=false
CPU_THREADS=4
