# API host port exposed by Docker Compose.
API_PORT=8000

# Comma-separated browser or upper-computer origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Runtime logging.
LOG_LEVEL=INFO

# Persistent runtime data paths inside the container.
ONLINE_HISTORY_DIR=/app/data/online
TABPFN_MODEL_CACHE_DIR=/app/models/tabpfn_cache

# CPU 工控机：TabPFN 单次推理 ~43s，不可用于实时优化。USE_BACKUP=true 使用 XGBoost 替代。
# GPU 服务器可设 USE_BACKUP=false 启用 TabPFN，精度更高但需 CUDA。
MODEL_DEVICE=cpu
USE_BACKUP=true
CPU_THREADS=4
